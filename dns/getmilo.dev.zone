; Zone file for getmilo.dev
; Generated from verified AgentMail domain records on 2026-03-12
; NOTE: Primary brand domain. Do not use for cold outbound.

; Google Postmaster / Google verification
@ IN TXT "google-site-verification=Lb2IeNUkpX0I1xVmhGHgW3vl0V-GzMGuLIsC_Zhsbck"

; DKIM
agentmail._domainkey IN TXT "v=DKIM1; k=rsa; "

; MX
@ IN MX 10 inbound-smtp.us-east-1.amazonaws.com.
mail IN MX 10 feedback-smtp.us-east-1.amazonaws.com.

; SPF
mail IN TXT "v=spf1 include:amazonses.com -all"

; DMARC
_dmarc IN TXT "v=DMARC1; p=reject; rua=mailto:dmarc@getmilo.dev"
