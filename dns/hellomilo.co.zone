; Zone file for hellomilo.co
; AgentMail email infrastructure
; Generated 2026-03-09

; DKIM
agentmail._domainkey IN TXT "v=DKIM1; k=rsa; "

; MX Records
@    IN MX 10 inbound-smtp.us-east-1.amazonaws.com.
mail IN MX 10 feedback-smtp.us-east-1.amazonses.com.

; SPF
mail IN TXT "v=spf1 include:amazonses.com -all"

; DMARC
; NOTE: Replace DOMAIN below with hellomilo.co
_dmarc IN TXT "v=DMARC1; p=reject; rua=mailto:dmarc@DOMAIN"
