; Zone file for milohq.co
; Generated from AgentMail create-domain response on 2026-03-12
; Purpose: secondary cold-outbound sending domain

; Google verification
@ IN TXT "google-site-verification=YTt57iQkWoInAkl6NA67VlNaCiFPdvBpybEIPSgSt-8"

; DKIM
agentmail._domainkey IN TXT "v=DKIM1; k=rsa; "

; MX
@ IN MX 10 inbound-smtp.us-east-1.amazonaws.com.
mail IN MX 10 feedback-smtp.us-east-1.amazonaws.com.

; SPF
mail IN TXT "v=spf1 include:amazonses.com -all"

; DMARC
_dmarc IN TXT "v=DMARC1; p=reject; rua=mailto:dmarc@milohq.co"
